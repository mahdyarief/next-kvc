# ==============================================
# 🗄️ DATABASE CONFIGURATION
# ==============================================
# PostgreSQL or MySQL connection string
# Format: postgresql://user:password@host:port/database?schema=public
# Or: mysql://user:password@host:port/database
# DATABASE_URL="postgresql://user:password@localhost:5432/db?schema=public"
DATABASE_URL="file:./prisma/local.db"

# ==============================================
# 🔐 AUTHENTICATION (NextAuth.js)
# ==============================================
# Generate a secure secret with: openssl rand -base64 32
AUTH_SECRET="your-super-secret-key-at-least-32-chars-change-this-in-production"

# Google OAuth Credentials (Required if enableGoogleAuth is true in the database)
GOOGLE_CLIENT_ID="your_google_client_id_here"
GOOGLE_CLIENT_SECRET="your_google_client_secret_here"

# Unified Base URL (Change this to your domain)
BASE_URL="http://localhost:3030"

# References BASE_URL
NEXTAUTH_URL="${BASE_URL}"

# Trust host for production deployment (required for proxied/reverse-proxy environments)
# Set to "true" if behind nginx, cloudflare, or similar proxy
AUTH_TRUST_HOST="true"

# Server Configuration
PORT="3030"
HOSTNAME="localhost"

# Public URLs (Derived from BASE_URL)
NEXT_PUBLIC_APP_URL="${BASE_URL}"
NEXT_PUBLIC_API_URL="${BASE_URL}/api"

# ==============================================
#  SWAGGER API DOCUMENTATION
# ==============================================
# Credentials for accessing Swagger UI at /swagger
# Note: Swagger UI is protected by basic auth using these credentials.
NEXT_PUBLIC_SWAGGER_USERNAME="admin"
NEXT_PUBLIC_SWAGGER_PASSWORD="admin123"

# ==============================================
# ⚙️ ADVANCED SETTINGS
# ==============================================
# Max file upload size in MB
MAX_UPLOAD_SIZE_MB="50"

# ==============================================
# 🌍 LOCALIZATION
# ==============================================
# Timezone for the server process (standard Node.js TZ)
TZ="Asia/Jakarta"

# ==============================================
#  STORAGE CONFIGURATION
# ==============================================
# Storage provider: local | vercel-blob | uploadthing
STORAGE_PROVIDER="local"

# (Vercel Blob Only) 
# BLOB_READ_WRITE_TOKEN="your_token_here"

# (UploadThing Only) Token from dashboard (v7+)
# UPLOADTHING_TOKEN="your_token_here"

# ==============================================
# ⚠️ NOTES
# ==============================================
# 1. Copy this file to .env before running the application
# 2. Never commit .env file to version control
# 3. Update values according to your environment
# 4. Generate secure AUTH_SECRET for production
# 5. Change Swagger credentials for production
# 6. Make sure DATABASE_URL is correct for your database
#
# For more information, visit:
# https://github.com/kelasvibecoding/NEXT-KVC
