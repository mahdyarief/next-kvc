{
  "name": "next-kvc",
  "version": "1.0.0",
  "packageManager": "bun@1.3.10",
  "private": false,
  "type": "module",
  "engines": {
    "node": ">=20",
    "bun": ">=1.1.0"
  },
  "scripts": {
    "db:config": "node scripts/prepare-db.cjs",
    "preinstall": "npx only-allow bun",
    "dev": "npm run db:config && node --import tsx src/server/index.ts",
    "build": "npm run db:config && npx prisma generate && next build",
    "start": "NODE_ENV=production node --import tsx src/server/index.ts",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "db:push": "bun run db:config && bunx prisma db push && bunx prisma generate",
    "db:studio": "bunx prisma studio",
    "typecheck": "tsc --noEmit",
    "add-admin": "node --import tsx scripts/setup-admin.ts",
    "format": "bun run prettier --write ."
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@prisma/adapter-better-sqlite3": "^7.4.2",
    "@prisma/adapter-mariadb": "^7.4.2",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/typography": "^0.5.19",
    "@types/react-syntax-highlighter": "^15.5.13",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.562.0",
    "mariadb": "^3.5.1",
    "mermaid": "^11.12.3",
    "moment": "^2.30.1",
    "moment-timezone": "^0.6.0",
    "next": "16.1.1",
    "next-auth": "^5.0.0-beta.30",
    "nextjs-toploader": "^3.9.17",
    "node-cron": "^4.2.1",
    "pg": "^8.19.0",
    "pino": "^10.1.0",
    "prisma": "^7.4.2",
    "react": "19.2.3",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.70.0",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19",
    "@types/swagger-ui-react": "^5.18.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "eslint-config-prettier": "^10.1.8",
    "next-swagger-doc": "^0.4.1",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "swagger-ui-react": "^5.31.0",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}